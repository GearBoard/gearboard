{
  "name": "api",
  "version": "1.0.0",
  "type": "module",
  "main": "src/server.ts",
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node .",
    "check": "tsc --noEmit",
    "db.create": "docker-compose up -d db",
    "db.start": "docker-compose start db",
    "db.stop": "docker-compose stop db",
    "db.down": "docker-compose down",
    "db.generate": "npx prisma generate",
    "db.push": "npx prisma db push",
    "db.studio": "npx prisma studio",
    "db.migrate": "npx prisma migrate dev",
    "db.apply": "npx prisma migrate deploy",
    "db.seed": "tsx prisma/seed.ts",
    "db.reset": "npx prisma migrate reset"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1015.0",
    "@google-cloud/storage": "^7.19.0",
    "@hono/node-server": "^2.0.6",
    "@hono/zod-validator": "^0.8.0",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "better-auth": "^1.5.5",
    "dotenv": "^16.4.5",
    "hono": "^4.12.27",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pg": "^8.13.0",
    "uuid": "^13.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.24",
    "prisma": "^7.0.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
}
